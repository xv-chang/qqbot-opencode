{
  "name": "qqbot-opencode",
  "version": "1.0.0",
  "description": "QQ Bot powered by OpenCode AI",
  "keywords": [
    "qq",
    "bot",
    "opencode",
    "ai",
    "chatbot",
    "qqbot"
  ],
  "type": "module",
  "main": "dist/app.js",
  "bin": {
    "qqbot": "./bin/qqbot.js"
  },
  "scripts": {
    "dev": "tsx src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.27",
    "js-yaml": "^4.1.0",
    "prompts": "^2.4.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "src/"
  ]
}
